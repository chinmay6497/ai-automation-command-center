# ---- LLM (optional) -------------------------------------------------------
# Groq API key (free: https://console.groq.com). Without it the app runs in
# deterministic heuristic-fallback mode — every flow still works.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Leads scoring at/above this go to the human approval queue
APPROVAL_SCORE_THRESHOLD=70

# ---- Channels (all optional — each activates when its key is set) ----------

# Telegram two-way channel: create a bot with @BotFather, paste the token.
# Localhost: leave BASE_URL empty (long-polling). Deployed: set BASE_URL to
# your public URL (e.g. https://myapp.onrender.com) for webhook mode.
TELEGRAM_BOT_TOKEN=
BASE_URL=

# Real outbound email on approval via Resend (free: https://resend.com).
# Sandbox sender (onboarding@resend.dev) can email only your own address;
# verify a domain to email anyone, then set EMAIL_FROM accordingly.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Slack incoming-webhook URL — hot-lead / high-risk alerts.
SLACK_WEBHOOK_URL=

# Protect machine intake (n8n/Zapier/curl must send X-API-Key: <this value>).
# Dashboard and contact page stay open. Leave empty to disable.
INTAKE_API_KEY=
